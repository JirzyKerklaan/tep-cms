{% extends "layouts/main.twig" %}

{% block body %}
  <h1>Search</h1>

  <form action="/search" method="GET">
    <input type="text" name="q" value="{{ query }}" placeholder="Search content..." />
    <button type="submit">Search</button>
  </form>

  {% if query and results.length === 0 %}
    <p>No results found for "{{ query }}".</p>
  {% endif %}

  {% if results.length > 0 %}
    <ul>
      {% for result in results %}
      <li>
        <strong>{{ result.title }}</strong> — {{ result.type }} — <code>{{ result.slug }}</code>
      </li>
      {% endfor %}
    </ul>
  {% endif %}
{% endblock %}