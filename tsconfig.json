{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "outDir": "public/dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "typeRoots": [
      "./core/types",
      "./node_modules/@types"
    ],
    "baseUrl": ".",
    "paths": {
      "@core/*": ["core/*"],
      "@src/*": ["src/*"],
      "@root/*": ["*"],
    }
  },
  "include": [
    "**/*.ts"
  ]
}
